#include <stdio.h>

#define YES  1 //присваивание сокращений 
#define NO   0

int main(void)
{
    int c; //переменная для хранения одного символа
    int flag = NO; //индикатор для определения нахождения внутри слова
    int found_a = NO;
    int cnt = 0; //счетчик начинается с 0

    printf("Введите текст:\n");

    while ((c = getchar()) != EOF) //цикл, где будет обрабатыватся по одному символу до конца файла
    {
        // Обработка вывода с маркерами и сменой регистра
        if (c == 'a')
        {
            putchar('<');  // маркер перед буквой
            putchar('A');  // меняем регистр на заглавный
            putchar('>');  // маркер после буквы
        }
        else if (c == 'A')
        {
            putchar('<');  // маркер перед буквой
            putchar('a');  // меняем регистр на строчный
            putchar('>');  // маркер после буквы
        }
        else
        {
            putchar(c);  // все остальные символы выводим без изменений
        }

        // Основная логика подсчёта слов с буквой 'a'/'A' (не изменена)
        if (c == ' ' || c == '.' || c == ',' || c == '\n' || c == '\t') // определение разделителя
        {
            if (flag == YES && found_a == YES) //проверка условий на нахождение внутри слова и найденной буквы а
            {
                cnt++; // если условия выполнены, то счетчик увеличивается
            }
            flag = NO; //сброс флагов для перехода к следующему слову
            found_a = NO;
        }
        else
        {
            flag = YES; //определитель внутри слова
            if (c == 'a' || c == 'A')  // найдена латинская 'a'
            {
                found_a = YES; //запоминает, что есть буква а
            }
        }
    }

    printf("number of words with letter 'a' = %d\n", cnt);
    return 0;
}
