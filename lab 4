#include <stdio.h>
#include <ctype.h>  // необходим для функции tolower()

// определение символических констант
#define YES 1
#define NO 0
#define MAXLINE 1000

void process_line(char buffer[]);

int main(void)
{
    char line[MAXLINE];
    fgets(line, MAXLINE, stdin);
    process_line(line);
    printf( "%s\n", line); //функция вывода с спецификатором формата - выводом сторки
    return 0;
}

void process_line(char buffer[]) //объявление функции которая обрабатывает строку из массива buffer 
{
    char c;        // текущий символ
    int prev_c;    // предыдущий символ
    int flag;      // признак нахождения внутри слова
    int i;       // позиция текущего символа исходной строки
    int pos;     // позиция текущего символа результирующей строки
    int start;   // позиция начала слова
    int j;

    // начальные присваивания 
    flag = NO;
    prev_c = ' '; //для начала определения начала слова
    start = 0;
    i = 0;
    pos = 0;

    // цикл чтения символов из строки
    do
    {
        c = buffer[i];

        // проверяем, является ли символ разделителем (пробел, табуляция, конец строки и т.д.)
        if (c == ' ' || c == '\t' || c == '\n' || c == '\0' || c == ',' || c == '.' || c == ';' || c == ':')
        {
            if (flag == YES) // если мы были внутри слова
            {
                // проверяем, совпадает ли первая и последняя буква слова (игнорируя регистр)
                if (tolower(buffer[start]) != tolower(buffer[i - 1]))
                {
                    // слово не подлежит удалению — копируем его в результирующую строку
                    for (j = start; j < i; j++)
                        buffer[pos++] = buffer[j];
                }
                flag = NO;
            }
            // копируем разделитель в результирующую строку, кроме случая конца строки
            if (c != '\0')
                buffer[pos++] = c;
        }
        else
        {
            // нашли букву — начинаем или продолжаем слово
            if (flag == NO)
            {
                start = i; // запоминаем позицию начала слова
                flag = YES;
            }
        }

        prev_c = c; //сохраняет чистоту проверки
        i++;
    }
    while (c != '\0');

    buffer[pos] = '\0'; // завершаем результирующую строку нуль‑символом
}
