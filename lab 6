#include <stdio.h> #include <locale.h>

#define N 3 // количество строк (можно изменить) #define K 4 // количество столбцов (можно изменить)

int main(void) { setlocale(LC_ALL, "RUS");
int x[N][K] = {0}; // двумерный массив int i, j, diff, flag;

// Ввод элементов массива
printf("Введите элементы массива %dx%d:\n", N, K); for (i = 0; i < N; i++) {
for (j = 0; j < K; j++) { scanf_s ("%d", & x[i][j]);
}
}

// Проверка каждой строки на арифметическую прогрессию for (i = 0; i < N; i++) {
flag = 1; //
diff = x[i] - x[i]; // разность прогрессии (для первой пары элементов)

// Проверяем, что разность между всеми соседними элементами одинакова for (j = 1; j < K - 1; j++) {
if (x[i][j + 1] - x[i][j] != diff) { flag = 0;
break;
}
}

// Вывод результата для текущей строки if (flag == 1) {
printf("Строка %d — арифметическая прогрессия.\n", i + 1);
}
else {
printf("Строка %d — не является арифметической прогрессией.\n", i + 1);
}
}

return 0;
}
