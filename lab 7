#include <stdio.h>

int main(void)
{
    long N;
    int K;
    unsigned long num;
    int num_bits;
    unsigned long temp;
    int i;

    printf("N = "); 
    scanf("%ld", &N); // Исправлено: %ld для long

    printf("K = "); 
    scanf("%d", &K);

    num = (unsigned long)N;

    // Определяем количество значимых битов в числе (до 32 бит)
    num_bits = 0;
    temp = num;
    while (temp != 0) {
        num_bits++;
        temp >>= 1;
    }
    if (num_bits == 0) num_bits = 1; // если число 0, считаем, что бит один

    // Нормализуем К — учитываем, что сдвиг на num_bits даёт исходное число
    K = K % 32;
    if (K < 0) K += 32; // если К отрицательный, приводим к положительному эквиваленту

    // Выполняем циклический сдвиг влево на К разрядов
    if (K != 0) {
        // Выделяем старшие К битов (они уйдут в конец)
        unsigned long high_bits = num >> (32 - K);
        // Сдвигаем число влево на К позиций (с потерей старших битов)
        num <<= K;
        // Объединяем: сдвигаем и добавляем старшие биты в конец
        num |= high_bits;
    }

    // Исправлено: выводим беззнаковое число через %lu
    printf("result: %lu\n", num); 
    return 0;
}
